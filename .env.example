# CueGuide Environment Variables
# Copy this file to .env.local and fill in real values

# === SUPABASE (shared across web + mobile) ===
# Get these from: https://supabase.com/dashboard/project/kueqtpekkqapclczvahc/settings/api
VITE_SUPABASE_URL=https://kueqtpekkqapclczvahc.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# === ELEVENLABS (text-to-speech) ===
# Get from: https://elevenlabs.io/app/developers/api-keys
# ELEVENLABS_API_KEY must stay server-side. Do not prefix it with VITE_.
VITE_USE_ELEVENLABS=true
ELEVENLABS_API_KEY=your_rotated_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=hpp4J3VqNfWAUOO0d1Us
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# Optional: only enable if the ElevenLabs account/key accepts voice_settings for the selected model.
ELEVENLABS_ENABLE_VOICE_SETTINGS=false
# Optional local dev only: bind ElevenLabs calls to Wi-Fi when a VPN must stay on.
ELEVENLABS_LOCAL_ADDRESS=

# === OPENROUTER (AI - recommended, free credits for new accounts) ===
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_server_side_openrouter_api_key_here

# === TWILIO (SMS alerts) ===
# Get from: https://twilio.com/console
VITE_TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN must stay server-side when SMS is enabled.

# === SENTRY (crash reporting - optional but recommended for production) ===
# Get from: https://sentry.io/settings/ → Projects → Create Project
VITE_SENTRY_DSN=your_sentry_dsn_here
