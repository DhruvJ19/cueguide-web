# CueGuide Mobile App Environment Variables
# Copy this file to .env.local and fill in real values

# === SUPABASE ===
EXPO_PUBLIC_SUPABASE_URL=https://kueqtpekkqapclczvahc.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# === CUEGUIDE WEB API PROXY ===
# Mobile must call the CueGuide backend. Do not expose ElevenLabs/OpenRouter secrets in Expo public env.
EXPO_PUBLIC_CUEGUIDE_API_BASE_URL=https://cueguide-web.vercel.app

# === AI AND VOICE ===
# Server-only provider keys live on the web/API deployment:
# ELEVENLABS_API_KEY, OPENROUTER_API_KEY.

# === TWILIO (SMS alerts) ===
EXPO_PUBLIC_TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN must remain server-side when SMS is enabled.
