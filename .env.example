# CueGuide Environment Variables
# Copy this file to .env.local and fill in real values

# === SUPABASE (shared across web + mobile) ===
# Get these from: https://supabase.com/dashboard/project/kueqtpekkqapclczvahc/settings/api
VITE_SUPABASE_URL=https://kueqtpekkqapclczvahc.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# === ELEVENLABS (text-to-speech) ===
# Get from: https://elevenlabs.io → Profile → API Key
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# === OPENROUTER (AI - recommended, free credits for new accounts) ===
# Get from: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# === GEMINI (AI prompts - alternative) ===
# Get from: https://aistudio.google.com → API Key
VITE_GEMINI_API_KEY=

# === TWILIO (SMS alerts) ===
# Get from: https://twilio.com/console
VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid
VITE_TWILIO_AUTH_TOKEN=your_twilio_auth_token
VITE_TWILIO_PHONE_NUMBER=+1234567890