{
  "expo": {
    "name": "CueGuide",
    "slug": "CueGuide",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "cueguide",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f8f4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cueguide.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "CueGuide can read selected health signals only after caregiver consent to help review care patterns alongside medication routines.",
        "NSHealthUpdateUsageDescription": "CueGuide does not write medication administration proof to Apple Health. Future health writes require explicit caregiver consent."
      },
      "associatedDomains": ["applinks:cueguide.app"]
    },
    "android": {
      "package": "com.cueguide.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f7f8f4"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "minSdkVersion": 26,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#166a5a",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cueguide-production"
      }
    }
  }
}
