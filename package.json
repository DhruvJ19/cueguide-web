{
  "name": "cueguide-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host=127.0.0.1 --port=3006 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "tsx src/__tests__/careflows.test.ts",
    "smoke:careflow": "tsx scripts/smoke-careflow.ts",
    "proof:supabase": "tsx scripts/prove-supabase-cloud.ts",
    "security:audit": "npm audit --audit-level=moderate && npm audit signatures",
    "security:lockfile": "tsx scripts/check-lockfile-security.ts",
    "security:secrets": "tsx scripts/check-secret-exposure.ts",
    "security:all": "npm run security:lockfile && npm run security:secrets && npm run security:audit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.105.3",
    "@tailwindcss/vite": "^4.1.14",
    "@types/canvas-confetti": "^1.9.0",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-error-boundary": "^6.1.1",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@sentry/react": "^10.53.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
